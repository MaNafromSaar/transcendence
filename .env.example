# Copy this file to .env and fill values before starting the stack

# Postgres
POSTGRES_USER=your_postgres_user
POSTGRES_PASSWORD=your_postgres_password
POSTGRES_DB=your_database_name

# n8n basic auth (recommended to enable in non-dev)
N8N_BASIC_AUTH_ACTIVE=true
N8N_BASIC_AUTH_USER=your_n8n_user
N8N_BASIC_AUTH_PASSWORD=your_n8n_password
N8N_HOST=localhost
N8N_PROTOCOL=http

# pgAdmin
PGADMIN_DEFAULT_EMAIL=your_pgadmin_email
PGADMIN_DEFAULT_PASSWORD=your_pgadmin_password

# Optional: external host + webhook tunnel URL for n8n if you expose it
# N8N_WEBHOOK_URL=https://your-public-domain.tld
